    // ==================== Helper Methods ====================
    
    private int calculateRiskScore(Assignment assignment) {
        int score = 0;
        
        // Status-based risk
        switch (assignment.getStatus()) {
            case BLOCKED -> score += 40;
            case WAITING_FOR_CLIENT -> score += 20;
            case IN_PROGRESS -> score += 10;
            case PENDING -> score += 5;
            default -> score += 0;
        }
        
        // Priority-based risk
        switch (assignment.getPriority()) {
            case CRITICAL -> score += 30;
            case HIGH -> score += 20;
            case MEDIUM -> score += 10;
            default -> score += 0;
        }
        
        // Due date-based risk
        long daysRemaining = ChronoUnit.DAYS.between(LocalDate.now(), assignment.getDueDate());
        if (daysRemaining < 0) score += 40;
        else if (daysRemaining < 2) score += 25;
        else if (daysRemaining < 5) score += 15;
        
        return Math.min(score, 100);
    }
    
    private String getRiskLevel(int score) {
        if (score >= 80) return "CRITICAL";
        if (score >= 60) return "HIGH";
        if (score >= 40) return "MEDIUM";
        return "LOW";
    }
    
    private List<String> identifyRiskFactors(Assignment assignment) {
        List<String> factors = new ArrayList<>();
        
        if (assignment.getStatus() == AssignmentStatus.BLOCKED) {
            factors.add("Assignment is blocked");
        }
        
        long daysRemaining = ChronoUnit.DAYS.between(LocalDate.now(), assignment.getDueDate());
        if (daysRemaining < 0) {
            factors.add("Overdue by " + Math.abs(daysRemaining) + " days");
        } else if (daysRemaining < 3) {
            factors.add("Approaching deadline in " + daysRemaining + " days");
        }
        
        if (assignment.getPriority().ordinal() >= PriorityLevel.CRITICAL.ordinal()) {
            factors.add("Critical priority");
        }
        
        return factors;
    }
    
    private List<String> generateRecommendations(int riskScore, List<String> riskFactors) {
        List<String> recommendations = new ArrayList<>();
        
        if (riskScore >= 80) {
            recommendations.add("Escalate to team lead immediately");
            recommendations.add("Review and remove blockers");
        }
        
        if (riskScore >= 60) {
            recommendations.add("Allocate additional resources");
            recommendations.add("Update stakeholders on status");
        }
        
        if (riskFactors.contains("Assignment is blocked")) {
            recommendations.add("Investigate and resolve blocking issues");
        }
        
        if (recommendations.isEmpty()) {
            recommendations.add("Continue current progress");
        }
        
        return recommendations;
    }
    
    private List<String> generateTimelineRecommendations(String status, int estimatedDays) {
        List<String> recommendations = new ArrayList<>();
        
        if (status.equals("URGENT")) {
            recommendations.add("Accelerate task completion");
            recommendations.add("Reduce scope if necessary");
        } else if (status.equals("AT_RISK")) {
            recommendations.add("Allocate additional team members");
            recommendations.add("Prioritize blocking tasks");
        } else {
            recommendations.add("Maintain current pace");
        }
        
        return recommendations;
    }
    
    private String buildTaskReasoning(AssignmentTask task, Assignment assignment) {
        StringBuilder reasoning = new StringBuilder();
        
        reasoning.append("Priority: ").append(task.getPriority().toString()).append(". ");
        
        long daysUntilDue = ChronoUnit.DAYS.between(LocalDate.now(), task.getDueDate().toLocalDate());
        if (daysUntilDue <= 1) {
            reasoning.append("Due soon. ");
        }
        
        reasoning.append("Estimated: ").append(task.getEstimatedHours() != null ? 
            task.getEstimatedHours() : 4).append(" hours.");
        
        return reasoning.toString();
    }
    
    private String getEstimatedEffort(AssignmentTask task) {
        Integer hours = task.getEstimatedHours();
        if (hours == null) hours = 4;
        
        if (hours <= 2) return "QUICK";
        if (hours <= 8) return "STANDARD";
        return "EXTENDED";
    }
}
