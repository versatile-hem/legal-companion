    private final AssignmentRepository assignmentRepository;
    private final TaskRepository taskRepository;
    
    // ==================== Task Suggestions ====================
    
    public List<TaskSuggestionDTO> suggestNextTasks(UUID assignmentId) {
        Assignment assignment = assignmentRepository.findById(assignmentId)
            .orElseThrow(() -> new ResourceNotFoundException("Assignment", assignmentId));
        
        List<TaskSuggestionDTO> suggestions = new ArrayList<>();
        
        // Get incomplete tasks
        List<AssignmentTask> incompleteTasks = taskRepository.findByAssignmentIdAndStatusList(
            assignmentId, TaskStatus.PENDING
        );
        
        // Suggest highest priority, earliest due date tasks first
        incompleteTasks.stream()
            .sorted((t1, t2) -> {
                int priorityCompare = t2.getPriority().compareTo(t1.getPriority());
                if (priorityCompare != 0) return priorityCompare;
                return t1.getDueDate().compareTo(t2.getDueDate());
            })
            .limit(3)
            .forEach(task -> suggestions.add(
                TaskSuggestionDTO.builder()
                    .taskId(task.getId().toString())
                    .taskTitle(task.getTitle())
                    .reasoning(buildTaskReasoning(task, assignment))
                    .priority(task.getPriority().ordinal() + 1)
                    .estimatedEffort(getEstimatedEffort(task))
                    .build()
            ));
        
        return suggestions;
    }
    
    // ==================== Risk Analysis ====================
    
    public RiskAnalysisDTO analyzeRisk(UUID assignmentId) {
        Assignment assignment = assignmentRepository.findById(assignmentId)
            .orElseThrow(() -> new ResourceNotFoundException("Assignment", assignmentId));
        
        int riskScore = calculateRiskScore(assignment);
        String riskLevel = getRiskLevel(riskScore);
        List<String> riskFactors = identifyRiskFactors(assignment);
        List<String> recommendations = generateRecommendations(riskScore, riskFactors);
        
        return RiskAnalysisDTO.builder()
            .assignmentId(assignmentId.toString())
            .riskScore(riskScore)
            .riskLevel(riskLevel)
            .primaryRisk(riskFactors.isEmpty() ? "None" : riskFactors.get(0))
            .recommendation(recommendations.isEmpty() ? "Continue current progress" : recommendations.get(0))
            .build();
    }
    
    public List<RiskAnalysisDTO> getAllRiskAnalyses() {
        List<Assignment> assignments = assignmentRepository.findAll();
        return assignments.stream()
            .map(this::analyzeRisk)
            .collect(Collectors.toList());
    }
    
    // ==================== Timeline Estimation ====================
    
    public TimelineEstimateDTO estimateTimeline(UUID assignmentId) {
        Assignment assignment = assignmentRepository.findById(assignmentId)
            .orElseThrow(() -> new ResourceNotFoundException("Assignment", assignmentId));
        
        // Get remaining tasks
        List<AssignmentTask> remainingTasks = taskRepository.findByAssignmentIdAndStatusList(
            assignmentId, TaskStatus.PENDING
        );
        
        // Get in-progress tasks for momentum
        List<AssignmentTask> inProgressTasks = taskRepository.findByAssignmentIdAndStatusList(
            assignmentId, TaskStatus.IN_PROGRESS
        );
        
        // Calculate total estimated hours
        double totalHours = remainingTasks.stream()
            .mapToDouble(t -> t.getEstimatedHours() != null ? t.getEstimatedHours() : 4)
            .sum();
        
        double inProgressHours = inProgressTasks.stream()
            .mapToDouble(t -> t.getEstimatedHours() != null ? t.getEstimatedHours() : 4)
            .sum();
        
        // Estimate 6 hours productive work per day
        // Add momentum: in-progress tasks might be completed faster
        int estimatedDays = (int) Math.ceil((totalHours + inProgressHours) / 7.0);
        LocalDateTime estimatedCompletion = LocalDateTime.now().plusDays(estimatedDays);
        
        long totalTasks = remainingTasks.size() + inProgressTasks.size();
        int completionPercentage = totalTasks == 0 ? 100 : 
            (int) (100 * inProgressTasks.size() / totalTasks);
        
        String confidence = "HIGH";
        if (estimatedCompletion.toLocalDate().isAfter(assignment.getDueDate().toLocalDate())) {
            confidence = "LOW";
        }
        
        return TimelineEstimateDTO.builder()
            .assignmentId(assignmentId.toString())
            .estimatedDays(estimatedDays)
            .estimatedCompletion(estimatedCompletion)
            .completionPercentage(completionPercentage)
            .daysRemaining((int) ChronoUnit.DAYS.between(LocalDate.now(), 
                assignment.getDueDate().toLocalDate()))
            .confidence(confidence)
            .reasoning("Based on " + totalTasks + " remaining tasks")
            .build();
    }
    
    // ==================== Optimization Suggestions ====================
    
    public OptimizationSuggestionsDTO suggestOptimizations(UUID assignmentId) {
        Assignment assignment = assignmentRepository.findById(assignmentId)
            .orElseThrow(() -> new ResourceNotFoundException("Assignment", assignmentId));
        
        List<String> parallelizable = new ArrayList<>();
        List<String> resources = new ArrayList<>();
        List<String> urgent = new ArrayList<>();
        
        // Get all tasks
        List<AssignmentTask> allTasks = taskRepository.findByAssignmentId(assignmentId);
        
        // Suggestion 1: Parallel task execution
        long criticalPending = allTasks.stream()
            .filter(t -> t.getStatus() == TaskStatus.PENDING)
            .filter(t -> t.getPriority() == PriorityLevel.CRITICAL)
            .count();
        
        if (criticalPending > 2) {
            parallelizable.add("Execute " + criticalPending + " critical pending tasks in parallel");
        }
        
        // Suggestion 2: Resource allocation
        long unassignedTasks = allTasks.stream()
            .filter(t -> t.getAssignee() == null)
            .count();
        
        if (unassignedTasks > 0) {
            resources.add("Assign " + unassignedTasks + " pending tasks to team members");
        }
        
        // Suggestion 3: Urgent actions
        long daysRemaining = ChronoUnit.DAYS.between(LocalDate.now(), assignment.getDueDate().toLocalDate());
        if (daysRemaining < 0) {
            urgent.add("Address SLA breach: " + Math.abs(daysRemaining) + " days overdue");
        } else if (daysRemaining < 3) {
            urgent.add("Accelerate execution: only " + daysRemaining + " days to deadline");
        }
        
        return OptimizationSuggestionsDTO.builder()
            .assignmentId(assignmentId.toString())
            .parallelizableSteps(parallelizable.isEmpty() ? 
                List.of("Current task sequence is optimal") : parallelizable)
            .resourceSuggestions(resources.isEmpty() ? 
                List.of("All tasks are properly assigned") : resources)
            .urgentActions(urgent.isEmpty() ? 
                List.of("No urgent actions required") : urgent)
            .potentialTimeSaving("1-3 days")
            .overallRecommendation("Continue current pace with focus on resource allocation")
            .build();
    }
    
